# Copy this file to .env and fill in real values locally.
# Do not commit .env.

# Lingxing API
LINGXING_BASE_URL=https://openapi.lingxing.com
LINGXING_APP_ID=
LINGXING_APP_SECRET=
LINGXING_ACCESS_TOKEN=
LINGXING_TIMEOUT_SECONDS=30
LINGXING_MAX_RETRIES=8
LINGXING_PAGE_SIZE=100
LINGXING_PRODUCT_PAGE_SIZE=1000

# Lingxing endpoints
LINGXING_FBA_SHIPMENT_LIST_ENDPOINT=/erp/sc/routing/storage/shipment/getInboundShipmentList
LINGXING_FBA_SHIPMENT_DETAIL_ENDPOINT=/erp/sc/routing/storage/shipment/getInboundShipmentListMwsDetail
LINGXING_PRODUCT_LIST_ENDPOINT=/erp/sc/routing/data/local_inventory/productList
LINGXING_SKU_DETAIL_ENDPOINT=/erp/sc/routing/data/local_inventory/productInfo
LINGXING_BATCH_PRODUCT_DETAIL_ENDPOINT=/erp/sc/routing/data/local_inventory/batchGetProductInfo
LINGXING_BATCH_PRODUCT_DETAIL_ID_FIELD=productIds
LINGXING_PRODUCT_BATCH_SIZE=100
LINGXING_PURCHASE_ORDER_LIST_ENDPOINT=/erp/sc/routing/data/local_inventory/purchaseOrderList
LINGXING_PURCHASER_LIST_ENDPOINT=/erp/sc/routing/data/purchaser/lists
LINGXING_SUPPLIER_LIST_ENDPOINT=/erp/sc/data/local_inventory/supplier
LINGXING_PURCHASE_BATCH_ENDPOINT=

# Optional fallback when purchaser list API has no permission.
# Example: 113:深圳某公司;114:义乌某公司
LINGXING_PURCHASER_ID_NAME_MAP=

# Shipment filters
LINGXING_SHIPMENT_STATUS=已发货
LINGXING_SHIPMENT_STATUS_FIELD=status
LINGXING_SHIPMENT_TIME_FIELD=shipment_time
LINGXING_SHIPMENT_TIME_TYPE_FIELD=time_type
LINGXING_SHIPMENT_TIME_TYPE=0
LINGXING_SHIPMENT_WAREHOUSE_FIELD=wname
LINGXING_SHIPMENT_WAREHOUSE=亚马逊义乌仓库

# Shipment seller-to-department mapping. Keep the real Excel file local/server-side.
SHIPMENT_SELLER_DEPARTMENT_FILE=data/shop-operations.xlsx

# MySQL
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
MYSQL_TABLE=customs_bill_parcels
MYSQL_PRODUCT_TABLE=customs_product

# Optional SSH tunnel for MySQL. Recommended when MySQL is only reachable from a cloud server.
MYSQL_USE_SSH_TUNNEL=1
SSH_HOST=
SSH_PORT=22
SSH_USER=
SSH_PASSWORD=
